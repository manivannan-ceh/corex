# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=apk_version_control
DB_SSLMODE=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRATION_HOURS=24

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-s3-bucket-name

# ── Storage ───────────────────────────────────────────────────────────────────
# Use "local" for development, "s3" for production
STORAGE_TYPE=local
# APP_URL is only needed for local storage if accessing from a non-localhost IP
# Set this to your server's IP/domain e.g. http://172.30.202.97
APP_URL=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
